{
  "name": "design-system-antoinegourgue",
  "version": "0.5.0",
  "description": "A premium Design System for Nuxt 4 and Vue 3 — components, design tokens, Tailwind CSS preset.",
  "keywords": [
    "nuxt",
    "vue",
    "design-system",
    "components",
    "tailwindcss",
    "typescript",
    "ui"
  ],
  "license": "MIT",
  "homepage": "https://github.com/antoine-gourgue/design-system#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/antoine-gourgue/design-system.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/antoine-gourgue/design-system/issues"
  },
  "type": "module",
  "sideEffects": [
    "dist/runtime/assets/base.css"
  ],
  "exports": {
    ".": {
      "import": "./dist/module.mjs",
      "require": "./dist/module.cjs",
      "types": "./dist/module.d.ts"
    },
    "./module": {
      "import": "./dist/module.mjs",
      "require": "./dist/module.cjs",
      "types": "./dist/module.d.ts"
    },
    "./tailwind/preset": {
      "import": "./tailwind/preset.js",
      "require": "./tailwind/preset.js",
      "types": "./tailwind/preset.d.ts"
    },
    "./dist/runtime/*": "./dist/runtime/*"
  },
  "main": "./dist/module.cjs",
  "module": "./dist/module.mjs",
  "types": "./dist/module.d.ts",
  "typesVersions": {
    "*": {
      "*": ["./dist/*", "./dist/index.d.ts"]
    }
  },
  "files": [
    "dist",
    "tailwind",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "nuxt-module-build build",
    "stub": "nuxt-module-build build --stub",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,css}\""
  },
  "dependencies": {
    "@iconify-json/flagpack": "^1.0.8",
    "@iconify-json/simple-icons": "^1.2.36",
    "@iconify-json/devicon": "^1.2.18",
    "@nuxt/icon": "^1.10.3",
    "@nuxt/kit": "^3.15.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^3.14.0",
    "@nuxt/module-builder": "^0.8.4",
    "@nuxt/schema": "^3.15.0",
    "eslint": "^9.21.0",
    "nuxt": "^3.15.0",
    "prettier": "^3.5.0",
    "typescript": "^5.8.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.2.0"
  },
  "peerDependencies": {
    "@nuxtjs/tailwindcss": ">=6.0.0",
    "nuxt": ">=3.0.0",
    "tailwindcss": ">=3.0.0 <4.0.0",
    "vue": ">=3.4.0"
  },
  "peerDependenciesMeta": {
    "@nuxtjs/tailwindcss": {
      "optional": true
    },
    "tailwindcss": {
      "optional": true
    }
  }
}
